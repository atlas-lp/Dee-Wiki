# Set these in Cloud Run → Edit & Deploy → Variables & Secrets
# DO NOT put real keys here

# Required — Claude API for chat responses
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required — Gemini embeddings for semantic search + dynamic wiki page embeddings
GEMINI_API_KEY=your-gemini-api-key-here

# Required for wiki update persistence — wiki edits push back to GitHub
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=pathwaysresearch/Dee-Wiki
